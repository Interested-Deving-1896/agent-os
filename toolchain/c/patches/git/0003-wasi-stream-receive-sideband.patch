+int cmd_sideband__helper(int argc,
+			 const char **argv,
+			 const char *prefix UNUSED,
+			 struct repository *repo UNUSED)
+{
+	if (argc == 3 && !strcmp(argv[1], "demux"))
+		return recv_sideband(argv[2], STDIN_FILENO, STDOUT_FILENO);
+
+	if (argc == 5 && !strcmp(argv[1], "mux")) {
+		use_sideband = atoi(argv[2]);
+		use_keepalive = atoi(argv[3]);
+		keepalive_in_sec = atoi(argv[4]);
+		if (use_sideband <= 0 || use_keepalive < KEEPALIVE_NEVER ||
+		    use_keepalive > KEEPALIVE_ALWAYS)
+			return error("invalid sideband mux parameters");
+		return copy_to_sideband(STDIN_FILENO, STDOUT_FILENO, NULL);
+	}
+
+	return error("usage: git sideband--helper demux <label> | "
+		     "mux <packet-size> <keepalive-mode> <keepalive-seconds>");
+}
+
+struct sideband_worker {
+#ifdef __wasi__
+	struct child_process process;
+#else
+	struct async async;
+#endif
+};
+
+static int start_sideband_worker(struct sideband_worker *worker)
+{
+#ifdef __wasi__
+	int output = dup(STDOUT_FILENO);
+
+	if (output < 0)
+		return -1;
+	child_process_init(&worker->process);
+	strvec_pushl(&worker->process.args, "sideband--helper", "mux", NULL);
+	strvec_pushf(&worker->process.args, "%d", use_sideband);
+	strvec_pushf(&worker->process.args, "%d", use_keepalive);
+	strvec_pushf(&worker->process.args, "%d", keepalive_in_sec);
+	worker->process.git_cmd = 1;
+	worker->process.in = -1;
+	worker->process.out = output;
+	if (start_command(&worker->process))
+		return -1;
+	return worker->process.in;
+#else
+	memset(&worker->async, 0, sizeof(worker->async));
+	worker->async.proc = copy_to_sideband;
+	worker->async.in = -1;
+	if (start_async(&worker->async))
+		return -1;
+	return worker->async.in;
+#endif
+}
+
+static int finish_sideband_worker(struct sideband_worker *worker)
+{
+#ifdef __wasi__
+	return finish_command(&worker->process);
+#else
+	return finish_async(&worker->async);
+#endif
+}
