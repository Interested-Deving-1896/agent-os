Preserve resolved sideband safety policy in WASI helpers.

Git applies URL-specific sideband.allowControlCharacters configuration in the
transport process. WASI demultiplexes sideband traffic in a spawned multicall
helper rather than a native thread, so pass the already-resolved numeric policy
to that helper without exposing the remote URL (and possible credentials) in
the child argv.

--- a/sideband.c
+++ b/sideband.c
@@ -106,6 +106,35 @@
 	urlmatch_config_release(&config);
 }
 
+int sideband_get_allow_control_characters(void)
+{
+	const char *value;
+
+	if (allow_control_characters == ALLOW_CONTROL_SEQUENCES_UNSET) {
+		if (!repo_config_get_value(the_repository,
+					   "sideband.allowcontrolcharacters", &value))
+			sideband_allow_control_characters_config(
+				"sideband.allowcontrolcharacters", value);
+
+		if (allow_control_characters == ALLOW_CONTROL_SEQUENCES_UNSET)
+			allow_control_characters = ALLOW_DEFAULT_ANSI_SEQUENCES;
+	}
+
+	return allow_control_characters;
+}
+
+int sideband_set_allow_control_characters(int value)
+{
+	const int valid = ALLOW_ANSI_COLOR_SEQUENCES |
+		ALLOW_ANSI_CURSOR_MOVEMENTS | ALLOW_ANSI_ERASE |
+		ALLOW_ALL_CONTROL_CHARACTERS;
+
+	if (value < 0 || (value & ~valid))
+		return -1;
+	allow_control_characters = value;
+	return 0;
+}
+
