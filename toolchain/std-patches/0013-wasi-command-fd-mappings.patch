+    pub fn fd_mapping(&mut self, source: OwnedFd, target: u32) -> io::Result<()> {
+        if self.extra_fd_mappings.len() >= MAX_EXTRA_FD_MAPPINGS {
+            return Err(io::Error::other(
+                "child fd mapping limit (1024) exceeded; increase MAX_EXTRA_FD_MAPPINGS in the AgentOS patched std",
+            ));
+        }
+        if self
+            .extra_fd_mappings
+            .iter()
+            .any(|(_, existing)| *existing == target)
+        {
+            return Err(io::Error::new(
+                io::ErrorKind::InvalidInput,
+                format!("child file descriptor {target} has more than one mapping"),
+            ));
+        }
+
+        self.extra_fd_mappings.push((source, target));
+        Ok(())
+    }
+
+    /// Snapshot mapping sources that an earlier spawn action could overwrite.
+    ///
+    /// `dup2` actions execute sequentially in the child. A source descriptor can
+    /// also be another action's target, so emitting the mappings directly can
+    /// destroy a later source (including swaps such as 3->4, 4->3). Clone such
+    /// sources onto descriptors outside the complete target set first. Keeping
+    /// rejected clones alive makes the ordinary lowest-unused-fd allocation
+    /// advance without ever overwriting an unrelated parent descriptor.
+    fn prepare_extra_fd_mappings(
+        &self,
+        action_targets: &[u32],
+    ) -> io::Result<(Vec<(u32, u32)>, Vec<OwnedFd>)> {
+        let mut prepared = Vec::with_capacity(self.extra_fd_mappings.len());
+        let mut guards = Vec::new();
+
+        for (source, target) in &self.extra_fd_mappings {
+            let mut source_fd = source.as_raw_fd() as u32;
+            while action_targets.contains(&source_fd) {
+                let clone = source.try_clone()?;
+                source_fd = clone.as_raw_fd() as u32;
+                guards.push(clone);
+            }
+            prepared.push((source_fd, *target));
+        }
+
+        Ok((prepared, guards))
+    }
